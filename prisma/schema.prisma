generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String     @id @default(cuid())
  email          String     @unique
  passwordHash   String
  createdAt      DateTime   @default(now())
  cartItems      CartItem[]
  ordini         Ordine[]
  ultimoIndirizzo Json?
}

model CartItem {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId     Int
  taglia        String?
  quantita      Int       @default(1)
  createdAt     DateTime  @default(now())
  selezionatoAt DateTime? // quando è stato selezionato l'ultima volta; null = non selezionato

  @@unique([userId, productId, taglia])
}

model Ordine {
  id        String              @id @default(cuid())
  numero    String              @unique
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  indirizzo Json
  totale    Float
  createdAt DateTime            @default(now())
  articoli  ArticoloOrdinato[]
}

model ArticoloOrdinato {
  id        String  @id @default(cuid())
  ordineId  String
  ordine    Ordine  @relation(fields: [ordineId], references: [id], onDelete: Cascade)
  productId Int
  title     String
  image     String?
  price     Float
  quantita  Int
  taglia    String?
}
